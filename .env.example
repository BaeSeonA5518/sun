# ========== 로컬 개발 (브라우저에서 직접 TMDB 호출) ==========
# npm run dev 시 사용. 배포 빌드에는 포함되지 않습니다.
VITE_TMDB_API_KEY=여기에_TMDB_API_키

# 로컬에서 프록시만 쓰려면 (vercel dev 실행 시)
# VITE_FORCE_TMDB_PROXY=true

# ========== 서버 전용 (Vercel / Netlify 대시보드에도 동일 이름으로 등록) ==========
# 브라우저 번들에 절대 넣지 마세요. VITE_ 접두사 없음.
TMDB_API_KEY=여기에_TMDB_API_키
